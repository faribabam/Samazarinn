<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Samazarinn Jewelry | طلا و جواهرات سمازرین</title>
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
    <style>
        :root {
            --gold: #d4af37;
            --gold-gradient: linear-gradient(45deg, #f3e0aa, #d4af37, #aa7c11);
            --bg: #0a0a0a;
            --card-bg: #141414;
            --text: #ffffff;
            --border: #222222;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: background 0.3s, color 0.3s;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 5%;
            background: rgba(10, 10, 10, 0.95);
            border-bottom: 1px solid var(--border);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .brand-name {
            font-size: 26px;
            font-weight: 800;
            background: var(--gold-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
        }

        .nav-actions {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .btn {
            background: transparent;
            border: 1px solid var(--gold);
            color: var(--gold);
            padding: 8px 16px;
            cursor: pointer;
            border-radius: 4px;
            font-weight: bold;
        }

        .btn:hover {
            background: var(--gold);
            color: var(--bg);
        }

        /* بخش دسته‌بندی‌ها */
        .categories-bar {
            margin-top: 100px;
            display: flex;
            justify-content: center;
            gap: 15px;
            padding: 15px;
            background: #111;
        }

        .cat-filter {
            background: var(--card-bg);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 10px 20px;
            cursor: pointer;
            border-radius: 30px;
        }

        .cat-filter.active, .cat-filter:hover {
            border-color: var(--gold);
            color: var(--gold);
        }

        /* گرید محصولات سه‌بعدی */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
            padding: 40px 5%;
        }

        .product-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 15px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .product-card:hover {
            border-color: #444;
            box-shadow: 0 10px 20px rgba(0,0,0,0.5);
        }

        .threed-box {
            width: 100%;
            height: 300px;
            background: radial-gradient(circle, #222 0%, #0a0a0a 100%);
            position: relative;
        }

        model-viewer {
            width: 100%;
            height: 100%;
            --poster-color: transparent;
        }

        .product-info {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            flex-grow: 1;
        }

        .product-title {
            font-size: 1.3rem;
            color: var(--text);
        }

        .product-desc {
            font-size: 0.9rem;
            color: #aaa;
            line-height: 1.5;
        }

        .product-price {
            font-size: 1.2rem;
            color: var(--gold);
            font-weight: bold;
            margin-top: auto;
        }

        .buy-action-btn {
            background: var(--gold-gradient);
            color: #000;
            border: none;
            padding: 12px;
            font-weight: bold;
            cursor: pointer;
            border-radius: 6px;
            width: 100%;
            margin-top: 10px;
        }

        /* پنجره کناری سبد خرید */
        .cart-sidebar {
            position: fixed;
            top: 0;
            right: -400px;
            width: 380px;
            height: 100vh;
            background: var(--card-bg);
            box-shadow: -5px 0 20px rgba(0,0,0,0.8);
            z-index: 2000;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            transition: right 0.4s ease;
        }

        .cart-sidebar.open {
            right: 0;
        }

        body[dir="ltr"] .cart-sidebar {
            right: auto;
            left: -400px;
            transition: left 0.4s ease;
        }

        body[dir="ltr"] .cart-sidebar.open {
            left: 0;
        }

        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .cart-items {
            flex-grow: 1;
            overflow-y: auto;
        }

        .cart-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #1f1f1f;
        }

        /* المان شناور هوش مصنوعی */
        .ai-chat-widget {
            position: fixed;
            bottom: 30px;
            left: 30px;
            z-index: 1000;
        }

        body[dir="ltr"] .ai-chat-widget {
            left: auto;
            right: 30px;
        }

        .ai-toggle {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--gold-gradient);
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(212,175,55,0.4);
            font-size: 24px;
        }

        .ai-box {
            display: none;
            width: 320px;
            height: 400px;
            background: var(--card-bg);
            border: 1px solid var(--gold);
            border-radius: 12px;
            position: absolute;
            bottom: 75px;
            left: 0;
            flex-direction: column;
            overflow: hidden;
            box-shadow: 0 5px 25px rgba(0,0,0,0.7);
        }

        body[dir="ltr"] .ai-box {
            left: auto;
            right: 0;
        }

        .ai-box.active {
            display: flex;
        }

        .ai-header {
            background: #1a1a1a;
            padding: 15px;
            font-weight: bold;
            border-bottom: 1px solid var(--border);
            color: var(--gold);
        }

        .ai-messages {
            flex-grow: 1;
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
            font-size: 0.9rem;
        }

        .msg { padding: 8px 12px; border-radius: 8px; max-width: 85%; }
        .msg.user { background: #333; align-self: flex-end; }
        .msg.bot { background: var(--border); color: var(--gold); align-self: flex-start; }

        .ai-input-area {
            display: flex;
            border-top: 1px solid var(--border);
        }

        .ai-input-area input {
            flex-grow: 1;
            background: #050505;
            border: none;
            color: #fff;
            padding: 12px;
            outline: none;
        }

        .ai-input-area button {
            background: var(--gold);
            border: none;
            padding: 0 15px;
            cursor: pointer;
        }

        /* دکمه‌های چسبان شبکه‌های اجتماعی */
        .social-sticky {
            position: fixed;
            bottom: 30px;
            right: 30px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            z-index: 1000;
        }

        body[dir="ltr"] .social-sticky {
            right: auto;
            left: 30px;
        }

        .social-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            text-decoration: none;
            font-weight: bold;
            font-size: 0.8rem;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        .telegram { background: #0088cc; }
        .instagram { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }

        @media (max-width: 768px) {
            .cart-sidebar { width: 100%; right: -100%; }
            body[dir="ltr"] .cart-sidebar { left: -100%; }
        }
    </style>
</head>
<body>

    <header>
        <div class="brand-name">Samazarinn</div>
        <div class="nav-actions">
            <button class="btn" id="lang-btn" onclick="toggleLanguage()">EN</button>
            <button class="btn" id="cart-btn" onclick="toggleCart()">سبد خرید (0)</button>
        </div>
    </header>

    <section class="categories-bar">
        <button class="cat-filter active" onclick="filterCategory('all')" id="cat-all">همه محصولات</button>
        <button class="cat-filter" onclick="filterCategory('necklace')" id="cat-neck">گردنبند</button>
        <button class="cat-filter" onclick="filterCategory('bracelet')" id="cat-brace">دستبند</button>
        <button class="cat-filter" onclick="filterCategory('ring')" id="cat-ring">انگشتر</button>
    </section>

    <main class="products-grid">
        {% for product in products %}
        <div class="product-card" data-category="{{ product.category }}">
            <div class="threed-box">
                <model-viewer 
                    src="{{ product.model_url }}" 
                    alt="Samazarinn Gold 3D Asset"
                    auto-rotate 
                    camera-controls 
                    shadow-intensity="1.5" 
                    environment-image="neutral"
                    exposure="1.4"
                    interaction-prompt="none">
                </model-viewer>
            </div>
            <div class="product-info">
                <h3 class="product-title" data-fa="{{ product.fa.name }}" data-en="{{ product.en.name }}">{{ product.fa.name }}</h3>
                <p class="product-desc" data-fa="{{ product.fa.desc }}" data-en="{{ product.en.desc }}">{{ product.fa.desc }}</p>
                <div class="product-price" data-irr="{{ product.price_irr }}" data-usd="{{ product.price_usd }}">
                    {{ "{:,}".format(product.price_irr) }} تومان
                </div>
                <button class="buy-action-btn" onclick="addToCart('{{ product.id }}')" data-fa="افزودن به سبد خرید" data-en="Add to Cart">
                    افزودن به سبد خرید
                </button>
            </div>
        </div>
        {% endfor %}
    </main>

    <div class="cart-sidebar" id="sidebar-cart">
        <div class="cart-header">
            <h2 id="cart-title">سبد خرید شما</h2>
            <button class="btn" onclick="toggleCart()">X</button>
        </div>
        <div class="cart-items" id="cart-items-container">
            </div>
        <button class="buy-action-btn" style="margin-top:20px;" id="checkout-btn" data-fa="تسویه حساب نهایی" data-en="Proceed to Checkout">
            تسویه حساب نهایی
        </button>
    </div>

    <div class="ai-chat-widget">
        <button class="ai-toggle" onclick="toggleAIChat()">✨</button>
        <div class="ai-box" id="ai-chat-box">
            <div class="ai-header" id="ai-title">پشتیبان هوشمند سمازرین</div>
            <div class="ai-messages" id="ai-messages-wrap">
                <div class="msg bot" id="ai-welcome">سلام! چطور می‌تونم کمکتون کنم؟</div>
            </div>
            <div class="ai-input-area">
                <input type="text" id="ai-user-input" placeholder="سوال خود را بپرسید...">
                <button onclick="sendToAI()" id="ai-send-btn">ارسال</button>
            </div>
        </div>
    </div>

    <div class="social-sticky">
        <a href="https://instagram.com" target="_blank" class="social-btn instagram">Insta</a>
        <a href="https://t.me" target="_blank" class="social-btn telegram">Tel</a>
    </div>

    <script>
        let currentLang = "fa";
        let cart = [];

        // مدیریت زبان سایت
        function toggleLanguage() {
            currentLang = currentLang === "fa" ? "en" : "fa";
            document.documentElement.dir = currentLang === "fa" ? "rtl" : "ltr";
            document.documentElement.lang = currentLang;

            // به روز رسانی دکمه‌ها و متون سیستماتیک هدر
            document.getElementById("lang-btn").innerText = currentLang === "fa" ? "EN" : "FA";
            updateStaticText();
            renderCart();
        }

        function updateStaticText() {
            const isFa = currentLang === "fa";
            
            // کلمات کلیدی ثابت
            document.getElementById("cart-btn").innerText = isFa ? `سبد خرید (${cart.length})` : `Cart (${cart.length})`;
            document.getElementById("cat-all").innerText = isFa ? "همه محصولات" : "All Products";
            document.getElementById("cat-neck").innerText = isFa ? "گردنبند" : "Necklace";
            document.getElementById("cat-brace").innerText = isFa ? "دستبند" : "Bracelet";
            document.getElementById("cat-ring").innerText = isFa ? "انگشتر" : "Ring";
            document.getElementById("cart-title").innerText = isFa ? "سبد خرید شما" : "Your Cart";
            document.getElementById("checkout-btn").innerText = isFa ? "تسویه حساب نهایی" : "Proceed to Checkout";
            document.getElementById("ai-title").innerText = isFa ? "پشتیبان هوشمند سمازرین" : "Samazarinn AI Support";
            document.getElementById("ai-welcome").innerText = isFa ? "سلام! چطور می‌تونم کمکتون کنم؟" : "Hello! How can I assist you today?";
            document.getElementById("ai-user-input").placeholder = isFa ? "سوال خود را بپرسید..." : "Ask your question...";
            document.getElementById("ai-send-btn").innerText = isFa ? "ارسال" : "Send";

            // فیلدهای داینامیک محصولات داخل گرید
            document.querySelectorAll(".product-card").forEach(card => {
                const titleEl = card.querySelector(".product-title");
                const descEl = card.querySelector(".product-desc");
                const priceEl = card.querySelector(".product-price");
                const btnEl = card.querySelector(".buy-action-btn");

                titleEl.innerText = titleEl.getAttribute(`data-${currentLang}`);
                descEl.innerText = descEl.getAttribute(`data-${currentLang}`);
                btnEl.innerText = btnEl.getAttribute(`data-${currentLang}`);

                if (isFa) {
                    const price = parseInt(priceEl.getAttribute("data-irr")).toLocaleString();
                    priceEl.innerText = `${price} تومان`;
                } else {
                    priceEl.innerText = `$${priceEl.getAttribute("data-usd")}`;
                }
            });
        }

        // سیستم فیلترینگ کاتالوگ دسته‌بندی‌ها
        function filterCategory(category) {
            document.querySelectorAll(".cat-filter").forEach(btn => btn.classList.remove("active"));
            event.target.classList.add("active");

            document.querySelectorAll(".product-card").forEach(card => {
                if (category === "all" || card.getAttribute("data-category") === category) {
                    card.style.display = "flex";
                } else {
                    card.style.display = "none";
                }
            });
        }

        // کنترلر سبد خرید چسبان
        function toggleCart() {
            document.getElementById("sidebar-cart").classList.toggle("open");
        }

        function addToCart(productId) {
            cart.push(productId);
            document.getElementById("cart-btn").innerText = currentLang === "fa" ? `سبد خرید (${cart.length})` : `Cart (${cart.length})`;
            renderCart();
            // برای دسترسی سریع کاربر، سایدبار سبد خرید باز می‌شود
            document.getElementById("sidebar-cart").classList.add("open");
        }

        function renderCart() {
            const container = document.getElementById("cart-items-container");
            container.innerHTML = "";
            
            if(cart.length === 0) {
                container.innerHTML = currentLang === "fa" ? "<p>سبد خرید خالی است.</p>" : "<p>Cart is empty.</p>";
                return;
            }

            // شمارش تعداد هر محصول در سبد
            const counts = {};
            cart.forEach(x => counts[x] = (counts[x] || 0) + 1);

            document.querySelectorAll(".product-card").forEach(card => {
                // استخراج شناسه عددی کاتالوگ
                const id = card.querySelector(".buy-action-btn").getAttribute("onclick").match(/'([^']+)'/)[1];
                if (counts[id]) {
                    const name = card.querySelector(".product-title").getAttribute(`data-${currentLang}`);
                    const itemHtml = `
                        <div class="cart-item">
                            <span>${name} (x${counts[id]})</span>
                            <button class="btn" style="padding:2px 8px;" onclick="removeFromCart('${id}')">X</button>
                        </div>
                    `;
                    container.innerHTML += itemHtml;
                }
            });
        }

        function removeFromCart(id) {
            const index = cart.indexOf(id);
            if (index > -1) cart.splice(index, 1);
            document.getElementById("cart-btn").innerText = currentLang === "fa" ? `سبد خرید (${cart.length})` : `Cart (${cart.length})`;
            renderCart();
        }

        // کنترلر بخش ماژول هوش مصنوعی وب‌سایت
        function toggleAIChat() {
            document.getElementById("ai-chat-box").classList.toggle("active");
        }

        async function sendToAI() {
            const inputEl = document.getElementById("ai-user-input");
            const text = inputEl.value.trim();
            if (!text) return;

            const wrap = document.getElementById("ai-messages-wrap");
            wrap.innerHTML += `<div class="msg user">${text}</div>`;
            inputEl.value = "";
            wrap.scrollTop = wrap.scrollHeight;

            try {
                const response = await fetch("/api/ai-chat", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ message: text, lang: currentLang })
                });
                const data = await response.json();
                
                wrap.innerHTML += `<div class="msg bot">${data.response}</div>`;
                wrap.scrollTop = wrap.scrollHeight;
            } catch (e) {
                wrap.innerHTML += `<div class="msg bot">Error communicating with server AI.</div>`;
            }
        }
    </script>
</body>
</html>
